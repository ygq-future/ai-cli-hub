# ── 本地代理（本地网络无法连接到TG时配置）──
# Bun 不读 Windows 系统代理注册表，只认这两个环境变量。
# Bun 启动会自动把 .env 加载进 process.env，fetch 据此走代理，无需手动 export。
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# ── Telegram ──
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# ── 白名单（逗号分隔的 user id）──
WHITELIST_USER_IDS=11111111,22222222

# ── 数据库（Postgres）──
DATABASE_URL=postgres://hub:password@localhost:5432/ai_cli_hub

# ── 仅测试：仓储集成测试目标库（需 pgvector 扩展，如 pgvector/pgvector 镜像）。
#    不设则集成测试自动 skip。非 config/ 读取项，仅供 test/*.integration.test.ts。
TEST_DATABASE_URL=postgres://postgres:20030519@127.0.0.1:5432/ai_cli_hub_test

# ── 长期记忆 / 嵌入（API，不跑本地模型）──
EMBEDDING_API_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSIONS=1024
MEMORY_RECALL_TOP_K=10

# ── 长期记忆 / LLM 摘要（OpenAI-compatible chat completions；留空则无法生成 LLM 摘要）──
MEMORY_SUMMARY_API_BASE_URL=https://api.openai.com/v1
MEMORY_SUMMARY_API_KEY=sk-your-summary-key
MEMORY_SUMMARY_MODEL=gpt-4o-mini
MEMORY_SUMMARY_MAX_CHARS=600

# ── 生命周期超时 ──
# 已启动的 CLI/adapter 空闲超过该时间后自动关闭（5 分钟）；conversation 保持 idle，可再次唤醒
AGENT_IDLE_TIMEOUT_MS=300000
# 会话自动归档（天）
SESSION_ARCHIVE_DAYS=7

# ── 会话默认工作目录（可选，缺省 = 启动进程的 cwd；/cwd 可切换当前用户目标目录）──
# DEFAULT_CWD=/home/me/projects/foo

# ── Agent 职责定位（可选，注入 system hint）──
AGENT_DESCRIPTION="你是运行在个人 VPS 上的 AI CLI 远程会话管理助手，负责协助用户安全、高效地管理本机项目、命令执行、审批和长期记忆。"
RECENT_CONTEXT_LIMIT=10
RECENT_CONTEXT_MESSAGE_MAX_CHARS=1200

# ── 媒体/文件入站（M9）──
# Telegram photo/document/audio/video 等下载到受控目录；非图片文件上传时只登记 metadata/local_path，不自动解析正文。
MEDIA_DOWNLOAD_DIR=.data/media
MEDIA_MAX_FILE_BYTES=10485760
MEDIA_MAX_TEXT_CHARS=20000
MEDIA_PARSE_TIMEOUT_MS=30000

# ── OCR（Light OCR API，可选；留空则图片提示 OCR 未配置；PDF 等非图片文件上传时不自动 OCR）──
# API 契约：POST /ocr/file，multipart/form-data 字段 file，返回 { text, lines }
OCR_API_BASE_URL=http://localhost:8000
OCR_API_TIMEOUT_MS=30000

# ── 日志 ──
# debug | info | warn | error
LOG_LEVEL=info

# ── Claude Agent SDK 调试 ──
# true/1/on 时打印 SDK 返回的原始 JSON，并开启 orchestrator adapterStarted/sendUserInput/turnTimeout 诊断日志
DEBUG_AGENT_SDK_JSON=false
