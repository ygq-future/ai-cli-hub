# ── Telegram ──
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# ── 白名单（逗号分隔的 user id）──
WHITELIST_USER_IDS=11111111,22222222

# ── 数据库（Postgres）──
DATABASE_URL=postgres://hub:password@localhost:5432/ai_cli_hub

# ── 仅测试：仓储集成测试目标库（需 pgvector 扩展，如 pgvector/pgvector 镜像）。
#    不设则集成测试自动 skip。非 config/ 读取项，仅供 test/*.integration.test.ts。
# TEST_DATABASE_URL=postgres://hub:password@localhost:5432/ai_cli_hub_test

# ── 长期记忆 / 嵌入（API，不跑本地模型）──
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_MODEL=text-embedding-3-small
MEMORY_RECALL_TOP_K=6

# ── 生命周期超时 ──
PTY_IDLE_TIMEOUT_MS=300000      # 进程空闲回收（5 分钟）
SESSION_ARCHIVE_DAYS=7          # 会话自动归档（天）

# ── 日志 ──
LOG_LEVEL=info                  # debug | info | warn | error
