{
  "name": "ai-cli-hub",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && bun run lint:deps",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "setting:migrate": "bun scripts/setting-migrate.ts",
    "setting": "tsx scripts/setting.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "@clack/prompts": "1.7.0",
    "@opencode-ai/sdk": "^1.17.16",
    "drizzle-orm": "^0.45.2",
    "https-proxy-agent": "^9.1.0",
    "mammoth": "^1.12.0",
    "pdf-to-img": "^6.2.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "telegraf": "^4.16.3",
    "telegramify-markdown": "^1.3.3",
    "tsx": "^4.23.0",
    "unbash": "^4.0.2",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "file:vendor/claude-agent-sdk-native-stubs/darwin-arm64",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "file:vendor/claude-agent-sdk-native-stubs/darwin-x64",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "file:vendor/claude-agent-sdk-native-stubs/linux-arm64",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "file:vendor/claude-agent-sdk-native-stubs/linux-arm64-musl",
    "@anthropic-ai/claude-agent-sdk-linux-x64": "file:vendor/claude-agent-sdk-native-stubs/linux-x64",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "file:vendor/claude-agent-sdk-native-stubs/linux-x64-musl",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "file:vendor/claude-agent-sdk-native-stubs/win32-arm64",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "file:vendor/claude-agent-sdk-native-stubs/win32-x64"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bun": "latest",
    "@types/ws": "^8.18.1",
    "dependency-cruiser": "^16.8.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
