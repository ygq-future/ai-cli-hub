{
  "name": "ai-cli-hub",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && bun run lint:deps",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.201",
    "drizzle-orm": "^0.45.2",
    "mammoth": "^1.12.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "telegraf": "^4.16.3",
    "telegramify-markdown": "^1.3.3",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bun": "latest",
    "dependency-cruiser": "^16.8.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
