{
  "name": "ai-cli-hub",
  "module": "src/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "start": "bun src/main.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && bun run lint:deps",
    "lint:deps": "depcruise src --config .dependency-cruiser.cjs",
    "test": "bun test"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/bun": "latest",
    "dependency-cruiser": "^16.8.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.19.0"
  }
}
